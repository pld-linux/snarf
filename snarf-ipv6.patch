diff -urNp -x '*.orig' snarf-7.0.org/ftp.c snarf-7.0/ftp.c
--- snarf-7.0.org/ftp.c	2026-03-03 00:26:38.523005389 +0100
+++ snarf-7.0/ftp.c	2026-03-03 00:26:38.597980712 +0100
@@ -28,6 +28,8 @@
 #include "ftp.h"
 #include "options.h"
 
+extern int tcp_v6;
+
 void
 close_quit(int sock)
 {
@@ -166,24 +168,37 @@ get_passive_sock(UrlResource *rsrc, int
 {
         unsigned char *addr;
         struct sockaddr_in sa;
-        int sock, commas;
+        int sock = 0, commas;
         int x;
         char *line, *orig_line;
 
-        send_control(control, "PASV\r\n", NULL);
+	send_control(control, tcp_v6 ? "EPSV\r\n" : "PASV\r\n", NULL);
 
         if( !((line = get_line(rsrc, control)) &&
-              check_numeric("227", line)) ) {
+              check_numeric(tcp_v6 ? "229" : "227", line)) ) {
                 safe_free(line);
                 return 0;
         }
 
         orig_line = line;
-
+	
         if( strlen(line) < 4 ) {
                 safe_free(line);
                 return 0;
         }
+	
+	if (tcp_v6) {
+		line += 4;
+		while (*line && *line != '(')
+			line++;
+		if (*line == 0 || *++line == 0)
+			goto oops;
+		if (line[1] != line[0] || line[2] != line[0])
+			goto oops;
+		sock = tcp_connect(rsrc->url->host, atoi(line+3));
+                goto oops;
+	}
+
 
         commas = 0;
         while (*line)
@@ -229,6 +244,7 @@ get_passive_sock(UrlResource *rsrc, int
