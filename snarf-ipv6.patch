+	} else {
+	        /* connect the socket, filling in the important stuff */
+		sa.sin_family = AF_INET;
+		sa.sin_port = htons(port);
+		memcpy(&sa.sin_addr, host->h_addr,sizeof(sa.sin_addr));
+		
+		if(connect(sock_fd, (struct sockaddr *)&sa, sizeof(sa)) < 0){
+			perror(remote_host);
+			return 0;
+		}
+	}
 
         return sock_fd;
 }
